{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@aot-technologies/formio-react": ["./src/mocks/formio-react.ts"],
      "@aot-technologies/formiojs/*": ["./src/mocks/formiojs.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
